# LLM provider: "openai" | "bedrock"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS Bedrock (LLM_PROVIDER=bedrock 일 때 사용)
# 자격증명은 ~/.aws/credentials 또는 IAM 역할 사용 — .env에 키를 넣지 않는다
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_REGION=ap-southeast-1

# Vector DB
CHROMA_PERSIST_DIR=./data/processed/chroma
CHROMA_COLLECTION_NAME=langchain_docs
# 서버 모드 사용 시 설정 (docker compose). 비우면 로컬 PersistentClient.
CHROMA_HOST=
CHROMA_PORT=8000

# Retrieval
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Crawler
CRAWL_OUTPUT_DIR=./data/raw/langchain
CRAWL_MAX_PAGES=500
CRAWL_REQUEST_DELAY=0.5

# Logging
LOG_LEVEL=INFO
