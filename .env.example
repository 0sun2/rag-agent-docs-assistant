# LLM provider: "openai" | "bedrock"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS Bedrock (LLM_PROVIDER=bedrock 일 때 사용)
# 자격증명은 ~/.aws/credentials 또는 IAM 역할 사용 — .env에 키를 넣지 않는다
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_REGION=ap-southeast-1

# Vector DB
CHROMA_PERSIST_DIR=./data/processed/chroma
CHROMA_COLLECTION_NAME=langchain_docs
# 서버 모드 사용 시 설정 (docker compose). 비우면 로컬 PersistentClient.
CHROMA_HOST=
CHROMA_PORT=8000

# Agent docs_search 프로덕션 retrieval 구성 (기본: 로컬 GPU 최적 구성)
# AWS 배포 시: PROD_EMBEDDING_PROVIDER=bedrock / PROD_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0 / PROD_USE_RERANKER=false
#PROD_EMBEDDING_PROVIDER=huggingface
#PROD_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
#PROD_USE_RERANKER=true

# Agent memory / 스트리밍
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
HISTORY_MAX_TOKENS=8000

# Retrieval
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Crawler
CRAWL_OUTPUT_DIR=./data/raw/langchain
CRAWL_MAX_PAGES=500
CRAWL_REQUEST_DELAY=0.5

# Logging
LOG_LEVEL=INFO
